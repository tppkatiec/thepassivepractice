{
  "$schema": "https://schemas.anthropic.com/design-tokens.json",
  "brand": {
    "name": "The Private Practice Pro",
    "shortName": "TPPP"
  },
  "color": {
    "bg":            { "value": "#6772c3", "description": "Primary page background" },
    "primary":       { "value": "#8890cf", "description": "Lighter lavender — dominant on-bg element color" },
    "ink":           { "value": "#3a506a", "description": "Deep slate — grounding text, dark elements" },
    "surface":       { "value": "#fafafb", "description": "Off-white — cards, surfaces, body copy on dark bg" },
    "accent": {
      "lime":        { "value": "#daff00", "description": "Electric pop — CTAs, key highlights only" },
      "blush":       { "value": "#dcbed7", "description": "Soft pop — gentle emphasis, secondary accent" }
    }
  },
  "font": {
    "family": {
      "header":      { "value": "'Instrument Serif', Georgia, serif", "description": "Editorial headers, tracked tight" },
      "subheader":   { "value": "'Clash Display', 'Inter', sans-serif", "description": "Bold uppercase subheads" },
      "body":        { "value": "'Inter', system-ui, sans-serif", "description": "Default body copy" }
    },
    "weight": {
      "regular":     { "value": 400 },
      "medium":      { "value": 500 },
      "semibold":    { "value": 600 },
      "bold":        { "value": 700 }
    },
    "size": {
      "display":     { "value": "clamp(3rem, 8vw, 6rem)" },
      "h1":          { "value": "clamp(2.25rem, 5vw, 3.75rem)" },
      "h2":          { "value": "clamp(1.75rem, 3.5vw, 2.5rem)" },
      "h3":          { "value": "1.5rem" },
      "subhead":     { "value": "0.875rem" },
      "body":        { "value": "1rem" },
      "small":       { "value": "0.8125rem" }
    },
    "letterSpacing": {
      "header":      { "value": "-0.02em", "description": "Instrument Serif negative tracking" },
      "subhead":     { "value": "0.16em",  "description": "Clash Display wide tracking for uppercase" },
      "body":        { "value": "0" }
    },
    "lineHeight": {
      "tight":       { "value": 1.05 },
      "snug":        { "value": 1.25 },
      "normal":      { "value": 1.55 }
    }
  },
  "radius": {
    "sm":            { "value": "4px" },
    "md":            { "value": "10px" },
    "lg":            { "value": "20px" },
    "pill":          { "value": "999px" }
  },
  "space": {
    "1":             { "value": "0.25rem" },
    "2":             { "value": "0.5rem" },
    "3":             { "value": "0.75rem" },
    "4":             { "value": "1rem" },
    "6":             { "value": "1.5rem" },
    "8":             { "value": "2rem" },
    "12":            { "value": "3rem" },
    "16":            { "value": "4rem" },
    "24":            { "value": "6rem" }
  },
  "shadow": {
    "sm":            { "value": "0 1px 2px rgba(58, 80, 106, 0.08)" },
    "md":            { "value": "0 8px 24px rgba(58, 80, 106, 0.12)" },
    "lg":            { "value": "0 24px 60px rgba(58, 80, 106, 0.18)" }
  }
}
