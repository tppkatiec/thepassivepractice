{
  "manifest_version": 3,
  "name": "Fontspo",
  "description": "Hover over any text to instantly see its font family, weight, size, line height, letter spacing, color, and full CSS. Works on any website.",
  "version": "1.0.0",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
