{
  "manifest_version": 3,
  "name": "Squarespace Class Finder",
  "description": "Hover over elements on Squarespace pages to reveal CSS class names for blocks, sections, buttons, and more. Pairs perfectly with the Squarespace ID Finder.",
  "version": "1.0.0",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.squarespace.com/*",
        "*://*.squarespace-cdn.com/*",
        "*://*.sqsp.net/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
