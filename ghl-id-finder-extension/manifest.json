{
  "manifest_version": 3,
  "name": "GHL Class & ID Finder",
  "description": "Hover over elements on Go High Level pages to reveal CSS class names, IDs, and section identifiers for easy customization.",
  "version": "1.0.0",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.gohighlevel.com/*",
        "*://*.highlevel.com/*",
        "*://*.msgsndr.com/*",
        "*://*.leadconnectorhq.com/*",
        "*://*.myfunnelsite.com/*",
        "*://*.funnelwebhook.com/*",
        "*://*.gohlsites.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
