{
  "manifest_version": 3,
  "name": "Kajabi Class & ID Finder",
  "description": "Hover over elements on Kajabi pages to reveal CSS class names, IDs, section/block identifiers, and data attributes for easy customization.",
  "version": "1.0.0",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.mykajabi.com/*",
        "*://*.kajabi.com/*",
        "*://*.kajabi-knowledgebase.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
